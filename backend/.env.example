# ============================================
# AuthApp Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit your actual .env to git!
# ============================================

# ----- Database (local MySQL) -----
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mern_auth_db

# ----- JWT -----
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ----- Email (Mailtrap sandbox — free for testing) -----
# Sign up at https://mailtrap.io → Email Testing → SMTP Settings
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_mailtrap_username
EMAIL_PASS=your_mailtrap_password
EMAIL_FROM=noreply@authapp.com

# For Gmail, use:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your_app_password   (Google Account → Security → App Passwords)

# ----- Server -----
PORT=5000
NODE_ENV=development

# ----- Frontend URL (for reset password link in email) -----
FRONTEND_URL=http://localhost:3000
